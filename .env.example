# Totem Voice Assistant Configuration
# Copy to .env and fill in your values: cp .env.example .env

# Required: ElevenLabs API key (https://elevenlabs.io)
ELEVENLABS_API_KEY=your_key_here

# ElevenLabs voice ID (default: George)
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Required: OpenClaw gateway auth token
# Find yours: openclaw config get gateway.auth.token
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# Wake word (spoken phrase to activate voice assistant)
WAKE_WORD=hey totem

# Path to Vosk speech recognition model
VOSK_MODEL_PATH=~/vosk-model-small-en-us-0.15

# Audio tuning
SILENCE_THRESHOLD=500
MAX_RECORDING_SECONDS=30
SILENCE_DURATION_SECONDS=1.5
